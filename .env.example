APP_NAME=CERNIX
APP_KEY=
APP_ENV=production
APP_DEBUG=false
APP_URL=
APP_TIMEZONE=UTC
CERNIX_DEMO_MODE=false
CERNIX_SEED_ON_BOOT=false
RENDER_SKIP_SEED=true
CERNIX_ALLOW_PRODUCTION_RESET=false

# Render/PostgreSQL
DB_CONNECTION=pgsql
DATABASE_URL=
DB_URL=

# Runtime storage
LOG_CHANNEL=stderr
LOG_LEVEL=info
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=240
QUEUE_CONNECTION=database
# Use s3 in any deployed environment. Render's container filesystem is
# ephemeral: anything written to local disk is lost on restart/redeploy.
FILESYSTEM_DISK=s3

# --- Object storage (S3-compatible: Cloudflare R2, AWS S3, Backblaze B2) ---
# Uploaded student media (verification selfie, ID card, profile photo) is stored
# here. One bucket, two key prefixes; the bucket must stay PRIVATE with no public
# access. All reads go through short-lived signed URLs generated by the app.
#
# Cloudflare R2: create a bucket, then R2 > Manage API Tokens > Create API Token
# (Object Read & Write). The token screen shows the key id, secret, and the
# S3 endpoint. Region is literally "auto" for R2.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
# Account-specific S3 API endpoint, e.g. https://<account-id>.r2.cloudflarestorage.com
AWS_ENDPOINT=
# Required for R2 and Backblaze B2. Set to false for real AWS S3.
AWS_USE_PATH_STYLE_ENDPOINT=true
# Key prefixes within the bucket. Private holds selfies and ID cards.
AWS_PRIVATE_PREFIX=private
AWS_PUBLIC_PREFIX=public

# Optional HTTPS cookie hardening for public deployments
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Remita payment gateway
REMITA_BASE_URL=
REMITA_MERCHANT_ID=
REMITA_SERVICE_TYPE_ID=
REMITA_API_KEY=
REMITA_PUBLIC_KEY=
REMITA_SECRET_KEY=

# CERNIX crypto/QR deployment keys or external integrations, if configured
CERNIX_HMAC_KEY=
CERNIX_ENCRYPTION_KEY=
APP_JWT_SECRET=
JWT_SECRET=

# Mail defaults for production smoke tests
MAIL_MAILER=log
