APP_NAME=CERNIX
APP_KEY=
APP_ENV=production
APP_DEBUG=false
APP_URL=
APP_TIMEZONE=UTC
CERNIX_DEMO_MODE=false

# Render/PostgreSQL
DB_CONNECTION=pgsql
DATABASE_URL=
DB_URL=

# Runtime storage
LOG_CHANNEL=stderr
LOG_LEVEL=info
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=240
QUEUE_CONNECTION=database
FILESYSTEM_DISK=public

# Optional HTTPS cookie hardening for public deployments
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Remita payment gateway
REMITA_BASE_URL=
REMITA_MERCHANT_ID=
REMITA_SERVICE_TYPE_ID=
REMITA_API_KEY=
REMITA_PUBLIC_KEY=
REMITA_SECRET_KEY=

# CERNIX crypto/QR deployment keys or external integrations, if configured
CERNIX_HMAC_KEY=
CERNIX_ENCRYPTION_KEY=
APP_JWT_SECRET=
JWT_SECRET=

# Mail defaults for production smoke tests
MAIL_MAILER=log
